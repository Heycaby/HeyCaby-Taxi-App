# Copy to `.env` and/or `apps/rider/.env` / `apps/driver/.env`.
# IPA build merges: repo `.env` → `apps/<app>/.env` (later wins). Optional: ENV_FILE=...
# See scripts/ipa_build_env.template and scripts/build_ios_ipas.py (ALLOW_KEYS).

# --- Required for Supabase + Mapbox (IPAs fail build if empty after merge) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token-here

# --- Go API on AWS (ECS) — not used by Flutter IPA keys; set in task definition / Secrets Manager ---
# REDIS_URL=rediss://:password@master.xxx.cache.amazonaws.com:6379
# Never set REDIS_OPTIONAL in production; only for local dev without Redis. See backend/docs/REDIS.md.
# REDIS_OPTIONAL=true

# DRIVER_BILLING_PROVIDER=mollie
# APPLE_APPSTORE_SHARED_SECRET=your-app-specific-shared-secret
# When DRIVER_BILLING_PROVIDER=apple (or secret set with empty provider per backend defaults), iOS uses In-App Purchase; Mollie checkout stays available when provider is mollie.
# DRIVER_SKIP_GO_ONLINE_GATES=true — Go API: bypass document + billing gates for going available (E2E only).
# Legacy alias: DRIVER_REQUIRE_DOCUMENTS_FOR_ONLINE=false (same effect). Omit both in production.

# API_BASE_URL=https://api.heycaby.nl  # Legacy Go REST — empty in prod after Phase E cutover (see app_config.driver_rest_api_base_url)
# APP_PUBLIC_WEB_ORIGIN=https://heycaby.nl
# Grow / invite share links — App Store product pages (not heycaby.nl):
# RIDER_IOS_APP_STORE_URL=https://apps.apple.com/app/id6761512910
# DRIVER_IOS_APP_STORE_URL=https://apps.apple.com/app/id6761512563

# --- Rider: per-theme Mapbox styles (mapbox://…); empty uses Standard fallback ---
# MAPBOX_STYLE_DAYLIGHT=
# MAPBOX_STYLE_FRESH=
# MAPBOX_STYLE_BLOSSOM=
# MAPBOX_STYLE_TAXI_SHADE_6=mapbox://styles/mapbox/standard
# MAPBOX_STYLE_TAXI_SHADE_2=mapbox://styles/mapbox/navigation-day-v1
# MAPBOX_STYLE_FOREST_DUSK=mapbox://styles/mapbox/outdoors-v12
# MAPBOX_STYLE_ROSE_NOIR=mapbox://styles/mapbox/navigation-night-v1
# MAPBOX_STYLE_ALPINE_CREAM=mapbox://styles/mapbox/light-v11
# MAPBOX_STYLE_WARM_GLOSS=mapbox://styles/mapbox/streets-v12
# MAPBOX_STYLE_FROSTY_BLACK_WHITE=mapbox://styles/mapbox/navigation-night-v1
# MAPBOX_STYLE_FROSTY_BLACK_YELLOW=mapbox://styles/mapbox/navigation-night-v1
# MAPBOX_STYLE_MIDNIGHT_CARBON=
# MAPBOX_STYLE_DEFAULT=

# --- Driver: main map style ---
# MAPBOX_STYLE_NAVIGATION_DAY=

# --- Supabase Edge Functions (driver-agent FCM HTTP v1) ---
# Firebase service account JSON as a single line. Set in Supabase Dashboard → Edge Functions → Secrets: FIREBASE_SERVICE_ACCOUNT_JSON
# Do not commit Admin SDK downloads; root .gitignore ignores *-firebase-adminsdk-*.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Supabase Edge Functions (Phase C billing — driver-billing-*) ---
# Set in Supabase Dashboard → Edge Functions → Secrets (project fvrprxguoternoxnyhoj):
# MOLLIE_API_KEY=live_...
# MOLLIE_REDIRECT_URL=https://api.heycaby.nl/driver/payment/return
# APPLE_APPSTORE_SHARED_SECRET=...   (legacy subscription IAP only)
# Deploy: supabase functions deploy driver-billing-checkout driver-billing-sync driver-billing-apple-verify driver-billing-mollie-webhook --project-ref fvrprxguoternoxnyhoj
# Mollie webhook URL: https://fvrprxguoternoxnyhoj.supabase.co/functions/v1/driver-billing-mollie-webhook

# --- Driver: Veriff / legal ---
# Production Veriff HVP URL: set in Supabase public.app_config key driver_veriff_hvp_url (no IPA rebuild).
# Optional local override only (leave unset for normal dev if app_config has the URL):
# DRIVER_VERIFF_HVP_URL=
# DRIVER_TERMS_URL=
# DRIVER_TERMS_VERIFF_URL=
