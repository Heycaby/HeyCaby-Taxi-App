# HeyCaby Go Backend — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# Supabase
SUPABASE_URL=https://fvrprxguoternoxnyhoj.supabase.co
SUPABASE_SERVICE_KEY=          # Project Settings → API → service_role key
SUPABASE_JWT_SECRET=           # Project Settings → API → JWT Secret
SUPABASE_DB_URL=postgresql://postgres.fvrprxguoternoxnyhoj:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=8080
ENV=development                # development | staging | production

# Logging
LOG_LEVEL=info                 # debug | info | warn | error

# Mollie billing
MOLLIE_API_KEY=                 # Live key format: live_xxx (never commit)
MOLLIE_REDIRECT_URL=https://api.heycaby.nl/driver/payment/return
